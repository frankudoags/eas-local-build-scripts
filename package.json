{
  "name": "test",
  "main": "expo-router/entry",
  "version": "1.1.2",
  "scripts": {
    "start": "expo start --dev-client --clear",
    "start:dev": "APP_VARIANT=development expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android --device",
    "ios": "expo run:ios --device",
    "web": "expo start --web",
    "lint": "npm run lint:js && npm run lint:expo",
    "lint:js": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:expo": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-all": "npm run format && npm run lint:fix && npm run lint:expo && pnpm tsc",
    "test:watch": "jest --watchAll",
    "test": "jest",
    "prebuild": "expo prebuild --clean",
    "build:dev:android": "eas build --local --profile development --platform android",
    "build:preview:android": "eas build --platform android --profile preview --local --non-interactive --output=./android-preview.aab",
    "build:prod:android": "eas build --local --profile production --platform android --non-interactive --output ./android-prod.aab",
    "build:release:android": "eas build --local --profile release --platform android --non-interactive --output ./android-release.aab",
    "build:preview:ios": "eas build --local --profile preview --platform ios --output ./ios-preview.ipa --non-interactive && eas submit --profile preview --platform ios --path ./ios-preview.ipa --non-interactive",
    "build:release:ios": "eas build --local --profile release --platform ios --output ./ios-release.ipa --non-interactive && eas submit --profile release --platform ios --path ./ios-release.ipa --non-interactive",
    "build:prod:ios": "eas build --local --profile production --platform ios --output ./ios-prod.ipa --non-interactive && eas submit --profile production --platform ios --path ./ios-prod.ipa --non-interactive",
    "icons": "svgr assets/svg --native --out-dir lib/components/icons --typescript --icon --ignore-existing",
    "adb-log": "adb logcat *:S ReactNative:V ReactNativeJS:V grep \"com.oysterai.Oyster.preview\" > logs.txt",
    "deploy:preview": "./scripts/deploy-preview.sh",
    "deploy:preview:ios": "./scripts/deploy-preview.sh --platform ios",
    "deploy:preview:android": "./scripts/deploy-preview.sh --platform android",
    "deploy:preview:skip-tests": "./scripts/deploy-preview.sh --skip-tests",
    "deploy:prod": "./scripts/deploy-production.sh",
    "deploy:prod:ios": "./scripts/deploy-production.sh --platform ios",
    "deploy:prod:android": "./scripts/deploy-production.sh --platform android",
    "deploy:prod:skip-tests": "./scripts/deploy-production.sh --skip-tests",
    "deploy:release": "./scripts/deploy-release.sh",
    "deploy:release:ios": "./scripts/deploy-release.sh --platform ios",
    "deploy:release:android": "./scripts/deploy-release.sh --platform android",
    "deploy:release:skip-tests": "./scripts/deploy-release.sh --skip-tests",
    "oneshot:ios": "./scripts/deploy-preview.sh --platform ios && ./scripts/deploy-production.sh --platform ios && ./scripts/deploy-release.sh --platform ios",
    "oneshot:android": "./scripts/deploy-preview.sh --platform android && ./scripts/deploy-production.sh --platform android && ./scripts/deploy-release.sh --platform android",
    "release:preview": "./scripts/create-release.sh --type preview",
    "release:prod": "./scripts/create-release.sh --type production",
    "release:dev": "./scripts/create-release.sh --type development",
    "version:major": "./scripts/bump-version.sh major",
    "version:minor": "./scripts/bump-version.sh minor",
    "version:patch": "./scripts/bump-version.sh patch",
    "prepare": "husky"
  }
}
